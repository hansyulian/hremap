default_layer: default
# device_names: ["g502", "keychron k3 max keyboard"]
device_names: []

layers:

  # ─── Base Shift ─────────────────────────────────────────────────────────────
  # Shared parent for all gaming shift layers
  base_shift:
    mappings:
      - trigger: ["C"]
        action:
          type: key
          keys: ["NEXT_TRACK"]
 
      - trigger: ["Z"]
        action:
          type: key
          keys: ["PREV_TRACK"]
 
      - trigger: ["X"]
        action:
          type: key
          keys: ["PLAY_PAUSE"]
  default:
    mappings:
      # toggle layer - press F20 to toggle
      - trigger: ["F20"]
        action:
          type: layer
          layer: default_shift
          mode: shift
          
      - trigger: ["F21"]
        action:
          type: key
          keys: ["F12"]

      - trigger: ["F22"]
        action:
          type: key
          keys: ["F5"]

      - trigger: ["F23"]
        action:
          type: key
          keys: ["CTRL", "SHIFT", "TAB"]

      - trigger: ["F24"]
        action:
          type: key
          keys: ["CTRL", "TAB"]


  default_shift:
    parent: base_shift
    mappings:
      # WASD navigation
      - trigger: ["W"]
        action:
          type: key
          keys: ["UP"]
      - trigger: ["S"]
        action:
          type: key
          keys: ["DOWN"]
      - trigger: ["A"]
        action:
          type: key
          keys: ["LEFT"]
      - trigger: ["D"]
        action:
          type: key
          keys: ["RIGHT"]

      - trigger: ["MFORWARD"]
        action:
          type: key
          keys: ["PLAY_PAUSE"]

      - trigger: ["MBACK"]
        action:
          type: key
          keys: ["MUTE"]
      - trigger: ["CTRL","BTN_RIGHT"]
        action:
          type: launch
          command: "flameshot gui"

      - trigger: ["F21"]
        action:
          type: key
          keys: ["NEXT_TRACK"]

      - trigger: ["F22"]
        action:
          type: key
          keys: ["PREV_TRACK"]

      - trigger: ["F23"]
        action:
          type: key
          keys: ["META", "LEFT"]

      - trigger: ["F24"]
        action:
          type: key
          keys: ["META", "RIGHT"]
      - trigger: ["BTN_LEFT"]
        action:
          type: key
          keys: ["CTRL", "F4"]
      - trigger: ["Q"]
        action:
          type: key
          keys: ["HOME"]
      - trigger: ["E"]
        action:
          type: key
          keys: ["END"]
      - trigger: ["R"]
        action:
          type: key
          keys: ["DELETE"]
      - trigger: ["F"]
        action:
          type: key
          keys: ["BACKSPACE"]

  # ─── Gaming Base ────────────────────────────────────────────────────────────
  gaming_base:
    mappings:
      - trigger: ["F23"]          # Mouse Tilt Left → [
        action:
          type: key
          keys: ["LEFTBRACKET"]
 
      - trigger: ["F24"]          # Mouse Tilt Right → ]
        action:
          type: key
          keys: ["RIGHTBRACKET"]
 
      - trigger: ["F20"]          # Mouse Shift → Gaming Base Shift
        action:
          type: layer
          layer: gaming_base_shift
          mode: shift
 
      - trigger: ["F14"]          # Foot Center → Gaming Base Shift
        action:
          type: layer
          layer: gaming_base_shift
          mode: shift
 
      - trigger: ["BTN_EXTRA"]    # Mouse Forward → semicolon
        action:
          type: key
          keys: ["SEMICOLON"]
 
      - trigger: ["BTN_SIDE"]     # Mouse Back → apostrophe
        action:
          type: key
          keys: ["APOSTROPHE"]
 
      - trigger: ["F21"]          # Mouse DPI Up → minus
        action:
          type: key
          keys: ["MINUS"]
 
      - trigger: ["F22"]          # Mouse DPI Down → equal
        action:
          type: key
          keys: ["EQUAL"]
 
      - trigger: ["PAUSE"]        # Keyboard G1 → ESC
        action:
          type: key
          keys: ["ESC"]
 
      - trigger: ["F13"]          # Foot Left → Play/Pause
        action:
          type: key
          keys: ["PLAY_PAUSE"]
 
      - trigger: ["F15"]          # Foot Right → ESC
        action:
          type: key
          keys: ["ESC"]
 
      - trigger: ["F9"]           # Keyboard G3 → App Volume Toggle
        action:
          type: app_volume
          direction: mute
 
  # ─── Gaming Base Shift ──────────────────────────────────────────────────────
  gaming_base_shift:
    parent: base_shift
    mappings:
      - trigger: ["F23"]          # Mouse Tilt Left → backslash
        action:
          type: key
          keys: ["BACKSLASH"]
 
      - trigger: ["F24"]          # Mouse Tilt Right → numpad multiply
        action:
          type: key
          keys: ["NUMPAD_MULTIPLY"]
 
      - trigger: ["BTN_EXTRA"]    # Mouse Forward → M
        action:
          type: key
          keys: ["M"]
 
      - trigger: ["F21"]          # Mouse DPI Up → period
        action:
          type: key
          keys: ["PERIOD"]
 
      - trigger: ["F22"]          # Mouse DPI Down → slash
        action:
          type: key
          keys: ["SLASH"]
 
      - trigger: ["F9"]           # Keyboard G6 → ESC
        action:
          type: key
          keys: ["ESC"]
 
      - trigger: ["BTN_LEFT"]     # Left Click → F11
        action:
          type: key
          keys: ["F11"]
 
      - trigger: ["BTN_RIGHT"]    # Right Click → F12
        action:
          type: key
          keys: ["F12"]
 
      # WHEEL_UP → App Volume Up
      # WHEEL_DOWN → App Volume Down
      # Wire these via compositor scroll bindings or scroll remapping
 
  # ─── MMORPG ─────────────────────────────────────────────────────────────────
  mmorpg:
    parent: gaming_base
    mappings:
      - trigger: ["F21"]
        action:
          type: key
          keys: ["1"]
      - trigger: ["F22"]
        action:
          type: key
          keys: ["2"]
      - trigger: ["BTN_EXTRA"]
        action:
          type: key
          keys: ["3"]
      - trigger: ["BTN_SIDE"]
        action:
          type: key
          keys: ["4"]
      # - trigger: ["F21"]
      #   action:
