      #         delay_ms: 250

      # - trigger: ["BTN_EXTRA"]
      #   action:
      #     type: macro
      #     mode: hold
      #     steps:
      #       - keys: ["3"]
      #         delay_ms: 5
      #       - keys: ["3"]
      #         up: true
      #         delay_ms: 250

      # - trigger: ["CTRL", "BTN_EXTRA"]
      #   action:
      #     type: macro
      #     mode: hold
      #     steps:
      #       - keys: ["CTRL", "3"]
      #         delay_ms: 5
      #       - keys: ["CTRL", "3"]
      #         up: true
      #         delay_ms: 250

      # - trigger: ["ALT", "BTN_EXTRA"]
      #   action:
      #     type: macro
      #     mode: hold
      #     steps:
      #       - keys: ["ALT", "3"]
      #         delay_ms: 5
      #       - keys: ["ALT", "3"]
      #         up: true
      #         delay_ms: 250

      # - trigger: ["BTN_SIDE"]
      #   action:
      #     type: macro
      #     mode: hold
      #     steps:
      #       - keys: ["4"]
      #         delay_ms: 5
      #       - keys: ["4"]
      #         up: true
      #         delay_ms: 250

      # - trigger: ["CTRL", "BTN_SIDE"]
      #   action:
      #     type: macro
      #     mode: hold
      #     steps:
      #       - keys: ["CTRL", "4"]
      #         delay_ms: 5
      #       - keys: ["CTRL", "4"]
      #         up: true
      #         delay_ms: 250

      # - trigger: ["ALT", "BTN_SIDE"]
      #   action:
      #     type: macro
      #     mode: hold
      #     steps:
      #       - keys: ["ALT", "4"]
      #         delay_ms: 5
      #       - keys: ["ALT", "4"]
      #         up: true
      #         delay_ms: 250
 
      - trigger: ["F20"]          # Mouse Shift → MMORPG Shift
        action:
          type: layer
          layer: mmorpg_shift
          mode: shift
 
      - trigger: ["F14"]          # Foot Center → MMORPG Shift
        action:
          type: layer
          layer: mmorpg_shift
          mode: shift
 
      - trigger: ["GRAVE"]        # Backtick → ESC
        action:
          type: key
          keys: ["ESC"]
 
      - trigger: ["F19"]          # Keychron Extra 4 → Enter
        action:
          type: key
          keys: ["ENTER"]
 
  # ─── MMORPG Shift ───────────────────────────────────────────────────────────
  mmorpg_shift:
    parent: gaming_base_shift
    mappings:
      - trigger: ["F21"]          # Mouse DPI Up → semicolon
        action:
          type: key
          keys: ["SEMICOLON"]
 
      - trigger: ["F22"]          # Mouse DPI Down → Hold Left Click
        action:
          type: macro
          mode: hold
          steps:
            - keys: ["BTN_LEFT"]
              delay_ms: 10
            - keys: ["BTN_LEFT"]
              up: true
              delay_ms: 100
 
      - trigger: ["BTN_LEFT"]
        action:
          type: key
          keys: ["5"]
      # - trigger: ["BTN_LEFT"]
      #   action:
      #     type: macro
      #     mode: hold
      #     steps:
      #       - keys: ["5"]
      #         delay_ms: 5
      #       - keys: ["5"]
      #         up: true
      #         delay_ms: 250

      # - trigger: ["CTRL", "BTN_LEFT"]
      #   action:
      #     type: macro
      #     mode: hold
      #     steps:
      #       - keys: ["CTRL", "5"]
      #         delay_ms: 5
      #       - keys: ["CTRL", "5"]
      #         up: true
      #         delay_ms: 250

      # - trigger: ["ALT", "BTN_LEFT"]
      #   action:
      #     type: macro
      #     mode: hold
      #     steps:
      #       - keys: ["ALT", "5"]
      #         delay_ms: 5
      #       - keys: ["ALT", "5"]
      #         up: true
      #         delay_ms: 250
 
      - trigger: ["BTN_RIGHT"]    # Right Click → Hold 6
        action:
          type: key
          keys: ["6"]
 
      - trigger: ["SPACE"]        # Space → Hold Space
        action:
          type: macro
          mode: hold
          steps:
            - keys: ["SPACE"]
              delay_ms: 5
            - keys: ["SPACE"]
              up: true
              delay_ms: 50
 
      - trigger: ["F9"]           # Keyboard G6 → ESC
        action:
          type: key
          keys: ["ESC"]
 
      - trigger: ["1"]            # Number row → Numpad
        action:
          type: key
          keys: ["NUMPAD_1"]
 
      - trigger: ["2"]
        action:
          type: key
          keys: ["NUMPAD_2"]
 
      - trigger: ["3"]
        action:
          type: key
          keys: ["NUMPAD_3"]
 
      - trigger: ["4"]
        action:
          type: key
          keys: ["NUMPAD_4"]
 
      - trigger: ["5"]
        action:
          type: key
          keys: ["NUMPAD_5"]
 
      - trigger: ["6"]
        action:
          type: key
          keys: ["NUMPAD_6"]
 
      - trigger: ["7"]
        action:
          type: key
          keys: ["NUMPAD_7"]
 
      - trigger: ["8"]
        action:
          type: key
          keys: ["NUMPAD_8"]
 
      - trigger: ["9"]
        action:
          type: key
          keys: ["NUMPAD_9"]          
      
      
profiles:
  - wm_classes: ["gw2-64.exe"]
    layer: mmorpg
